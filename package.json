{
  "name": "sona",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Korean study feasibility spike workspace.",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace @sona/desktop && npm run build --workspace @sona/renderer",
    "spike:tokenizer": "tsx spikes/tokenizer/src/run-tokenizer-spike.ts",
    "spike:llm-fallback": "tsx spikes/llm-fallback/src/generate-fallback-spec.ts",
    "spike:sqlite-concurrency": "tsx spikes/sqlite-concurrency/src/run-sqlite-concurrency.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [
    "korean",
    "electron",
    "nextjs",
    "spikes"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.7"
  }
}
