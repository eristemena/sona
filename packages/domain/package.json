{
  "name": "@sona/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./content/*": {
      "types": "./dist/content/*.d.ts",
      "import": "./dist/content/*.js"
    },
    "./contracts/*": {
      "types": "./dist/contracts/*.d.ts",
      "import": "./dist/contracts/*.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./settings/*": {
      "types": "./dist/settings/*.d.ts",
      "import": "./dist/settings/*.js"
    },
    "./provenance/*": {
      "types": "./dist/provenance/*.d.ts",
      "import": "./dist/provenance/*.js"
    },
    "./artifacts/*": {
      "types": "./dist/artifacts/*.d.ts",
      "import": "./dist/artifacts/*.js"
    },
    "./benchmark/*": {
      "types": "./dist/benchmark/*.d.ts",
      "import": "./dist/benchmark/*.js"
    },
    "./fallback/*": {
      "types": "./dist/fallback/*.d.ts",
      "import": "./dist/fallback/*.js"
    },
    "./fixtures/*": {
      "types": "./dist/fixtures/*.d.ts",
      "import": "./dist/fixtures/*.js"
    },
    "./tokenizer/*": {
      "types": "./dist/tokenizer/*.d.ts",
      "import": "./dist/tokenizer/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ts-fsrs": "^5.3.2"
  }
}
